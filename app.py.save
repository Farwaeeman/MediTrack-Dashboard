        st.plotly_chart(sfig(fig), use_container_width=True)

    with c2:
        st.markdown(sec("❌ No-Show Rate by Service Line"), unsafe_allow_html=True)
        bc = [RED if v>20 else ORG if v>18 else TEAL for v in dv["noshow"]]
        fig2 = go.Figure(go.Bar(
            x=dv["noshow"],
            y=[f"{DEPT_ICN[d]} {d}" for d in dv["dept"]],
            orientation="h",
            marker=dict(color=bc, line=dict(width=0), cornerradius=5),
            text=[f"{v}%" for v in dv["noshow"]],
            textposition="outside", textfont=dict(size=12)
        ))
        fig2.add_vline(x=18.8, line_dash="dot", line_color="#475569",
                       annotation_text="Avg 18.8%", annotation_font=dict(color="#64748b", size=10))
        fig2.update_layout(bargap=0.32)
        st.plotly_chart(sfig(fig2), use_container_width=True)

    p1, p2 = st.columns(2)
    with p1:
        st.markdown(sec("🥧 Appointment Share"), unsafe_allow_html=True)
        fig_p = go.Figure(go.Pie(
            labels=[f"{DEPT_ICN[d]} {d}" for d in dv["dept"]],
            values=dv["appts"], hole=0.52,
            marker=dict(colors=[DEPT_HEX[d] for d in dv["dept"]], line=dict(color="#0f172a", width=3)),
            textfont=dict(size=11, color="#f1f5f9")
        ))
        fig_p.update_layout(
            paper_bgcolor=PBG, plot_bgcolor=PBG, height=290,
            margin=dict(l=4,r=4,t=28,b=4), showlegend=True,
            font=dict(color="#64748b", family="Inter"),
            legend=dict(bgcolor="rgba(0,0,0,0)", borderwidth=0, font=dict(size=11, color="#94a3b8")),
            annotations=[dict(text="<b style='color:#f1f5f9'>Appts</b>", x=0.5, y=0.5,
                              font=dict(size=13, color="#f1f5f9"), showarrow=False)]
        )
        st.plotly_chart(fig_p, use_container_width=True)

    with p2:
        st.markdown(sec("⭐ Satisfaction by Service Line"), unsafe_allow_html=True)
        sat_v = dept_df[dept_df["dept"].isin(sl_sel)]
        fig_s2 = go.Figure(go.Bar(
            x=[f"{DEPT_ICN[d]} {d}" for d in sat_v["dept"]],
            y=sat_v["satisfaction"],
            marker=dict(color=[DEPT_HEX[d] for d in sat_v["dept"]], line=dict(width=0), cornerradius=6),
            text=[f"⭐ {v}" for v in sat_v["satisfaction"]],
            textposition="outside", textfont=dict(size=11)
        ))
        fig_s2.update_layout(yaxis_range=[3, 5], bargap=0.35)
        st.plotly_chart(sfig(fig_s2, h=290), use_container_width=True)

    # Bubble chart
    st.markdown(sec("🔵 Appointments vs No-Show Rate","Bubble size = Revenue"), unsafe_allow_html=True)
    fig_b = px.scatter(dv, x="appts", y="noshow", size="revenue", color="dept",
                       text="dept", color_discrete_map=DEPT_HEX, size_max=80,
                       labels={"appts":"Appointments","noshow":"No-Show (%)","dept":"Service Line"})
    fig_b.update_traces(textposition="top center", textfont=dict(size=11, color="#f1f5f9"))
    fig_b.update_layout(showlegend=False)
    st.plotly_chart(sfig(fig_b, h=320), use_container_width=True)

    # Heatmap
    st.markdown(sec("🗺️ Heatmap: City × Service Line No-Show %"), unsafe_allow_html=True)
    np.random.seed(99)
    hm = np.round(np.random.uniform(15, 25, (len(CITIES), len(sl_sel))), 1)
    fig_h = go.Figure(go.Heatmap(
        z=hm, x=[f"{DEPT_ICN[d]} {d}" for d in sl_sel], y=CITIES,
        colorscale=[[0,"#134e4a"],[0.5,"#7c4a00"],[1,"#7f1d1d"]],
        text=hm, texttemplate="%{text}%",
        textfont=dict(color="#f1f5f9", size=12),
        showscale=True,
        colorbar=dict(tickfont=dict(color="#64748b"), outlinewidth=0),
        zmin=14, zmax=26
    ))
    st.plotly_chart(sfig(fig_h, h=270), use_container_width=True)


