top_city   = city_df.loc[city_df["revenue"].idxmax()]

# ─────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────
def sec(title, sub=""):
    s = f'<span style="font-size:11px;color:#475569;font-weight:500;margin-left:10px">{sub}</span>' if sub else ""
    return f'<div style="font-size:14px;font-weight:800;color:#f1f5f9;margin-bottom:12px;letter-spacing:-0.2px">{title}{s}</div>'

def ns_color(v):
    return RED if v > 30 else ORG if v > 25 else TEAL

def risk_tag(v):
    c, bg, lbl = (RED,"rgba(239,68,68,0.15)","🔴 High") if v>30 else \
                 (ORG,"rgba(249,115,22,0.15)","🟡 Medium") if v>25 else \
                 (TEAL,"rgba(20,184,166,0.15)","🟢 Low")
    return f'<span style="background:{bg};color:{c};border-radius:6px;padding:3px 10px;font-size:10px;font-weight:800;border:1px solid {c}33">{lbl}</span>'

def dept_badge(dept):
    c = DEPT_HEX.get(dept,"#94a3b8")
    i = DEPT_ICN.get(dept,"🏥")
    return f'<span style="background:{c}22;color:{c};border-radius:5px;padding:2px 8px;font-size:10px;font-weight:800;border:1px solid {c}44">{i} {dept}</span>'

