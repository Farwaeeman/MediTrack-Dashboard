PBG  = "#1e293b"
PGRD = "rgba(255,255,255,0.04)"
PFNT = "#64748b"
TEAL = "#14b8a6"
ORG  = "#f97316"
RED  = "#ef4444"
BLUE = "#3b82f6"
VIO  = "#8b5cf6"
PINK = "#ec4899"

def sfig(fig, h=320, legend=False):
    fig.update_layout(
        paper_bgcolor=PBG,
        plot_bgcolor=PBG,
        font=dict(family="Inter", color="#94a3b8", size=11),
        height=h,
        margin=dict(l=8, r=8, t=30, b=8),
        showlegend=legend,
        legend=dict(
            bgcolor="rgba(0,0,0,0)",
            borderwidth=0,
            font=dict(size=11, color="#94a3b8")
        ),
        xaxis=dict(
            gridcolor=PGRD,
            linecolor="#334155",
            tickfont=dict(size=11, color="#64748b"),
            showline=True
        ),
        yaxis=dict(
            gridcolor=PGRD,
            linecolor="rgba(0,0,0,0)",
            tickfont=dict(size=11, color="#64748b")
        ),
    )
    return fig

