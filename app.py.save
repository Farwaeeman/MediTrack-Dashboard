# TAB 3 — DOCTORS
# ══════════════════════════════════════════════
with tab3:

    # Filters
    f1, f2, f3 = st.columns([2.5, 2, 2])
    with f1:
        srch = st.text_input("🔍 Search doctor by name", placeholder="Type name… e.g. Sara, Ahmed, Fatima", key="doc_search")
    with f2:
        dept_f = st.selectbox("🏥 Service Line", ["All Service Lines"] + DEPTS, key="doc_dept")
    with f3:
        sort_s = st.selectbox("🔀 Sort By", [
            "No-Show % — High to Low",
            "No-Show % — Low to High",
            "Appointments — High to Low",
            "Revenue — High to Low",
        ], key="doc_sort")

    fdf = doc_df.copy()
    if srch and srch.strip():
        fdf = fdf[fdf["Doctor"].str.contains(srch.strip(), case=False, na=False)]
    if dept_f != "All Service Lines":
        fdf = fdf[fdf["Department"] == dept_f]

    sm = {
        "No-Show % — High to Low":    ("No-Show %",    False),
        "No-Show % — Low to High":    ("No-Show %",    True),
        "Appointments — High to Low": ("Appointments", False),
        "Revenue — High to Low":      ("Revenue",      False),
    }
    sc, asc = sm[sort_s]
    fdf = fdf.sort_values(sc, ascending=asc).reset_index(drop=True)

    st.markdown("<div style='height:8px'></div>", unsafe_allow_html=True)

    if fdf.empty:
        st.markdown("""
        <div style="background:#1e293b;border:1px solid #334155;border-radius:14px;
             padding:60px;text-align:center">
            <div style="font-size:36px;margin-bottom:12px">🔍</div>
            <div style="font-size:16px;font-weight:700;color:#f1f5f9">No doctors match your search</div>
            <div style="font-size:13px;color:#475569;margin-top:6px">Try a different name or service line filter</div>
        </div>""", unsafe_allow_html=True)
    else:
        # Summary metrics
        sm1, sm2, sm3, sm4 = st.columns(4)
        sm1.metric("Doctors Shown",    str(len(fdf)))
        sm2.metric("Avg No-Show %",    f"{fdf['No-Show %'].mean():.1f}%")
        sm3.metric("Avg Appointments", f"{int(fdf['Appointments'].mean()):,}")
        sm4.metric("Highest No-Show",  f"{fdf['No-Show %'].max()}%")

        st.markdown("<div style='height:14px'></div>", unsafe_allow_html=True)

        top_worst = fdf.nlargest(3, "No-Show %")
        top_best  = fdf.nsmallest(3, "No-Show %")

        pc1, pc2 = st.columns(2)

        with pc1:
            st.markdown(sec("🚨 Needs Attention — Highest No-Show"), unsafe_allow_html=True)
            for _, row in top_worst.iterrows():
                c    = RED if row["No-Show %"] > 30 else ORG
                bg   = "rgba(239,68,68,0.07)" if row["No-Show %"] > 30 else "rgba(249,115,22,0.07)"
                bdr  = "rgba(239,68,68,0.25)" if row["No-Show %"] > 30 else "rgba(249,115,22,0.25)"
                icon = DEPT_ICN.get(row["Department"], "🏥")
                pct  = int(min(row["No-Show %"] / 40 * 100, 100))
                st.markdown(f"""
                <div style="background:#1e293b;border:1px solid {bdr};border-left:4px solid {c};
                     border-radius:12px;padding:14px 18px;margin-bottom:9px;
                     box-shadow:0 4px 16px rgba(0,0,0,0.3)">
                    <div style="display:flex;align-items:center;justify-content:space-between">
                        <div style="display:flex;align-items:center;gap:12px;flex:1">
                            <div style="background:{c}18;width:40px;height:40px;border-radius:10px;
                                 display:flex;align-items:center;justify-content:center;font-size:20px;
                                 border:1px solid {c}33">{icon}</div>
                            <div style="flex:1">
                                <div style="font-size:13px;font-weight:700;color:#f1f5f9">{row["Doctor"]}</div>
                                <div style="font-size:11px;color:#475569;margin-top:2px;font-weight:500">
                                    {row["Department"]} · {row["Seniority"]} · {row["Appointments"]} appts
                                </div>
                                <div style="background:#334155;border-radius:4px;height:4px;margin-top:8px">
                                    <div style="width:{pct}%;height:100%;background:{c};border-radius:4px"></div>
                                </div>
                            </div>
                        </div>
                        <div style="text-align:right;margin-left:16px">
                            <div style="font-size:24px;font-weight:800;color:{c};letter-spacing:-0.5px">{row["No-Show %"]}%</div>
                            <div style="background:{c}18;color:{c};border-radius:6px;padding:2px 8px;
                                 font-size:10px;font-weight:800;display:inline-block;margin-top:4px;
                                 border:1px solid {c}33">Needs Attention</div>
                        </div>
                    </div>
                </div>""", unsafe_allow_html=True)

        with pc2:
            st.markdown(sec("🌟 Top Performers — Lowest No-Show"), unsafe_allow_html=True)
            for _, row in top_best.iterrows():
                icon = DEPT_ICN.get(row["Department"], "🏥")
                pct  = int(min(row["No-Show %"] / 40 * 100, 100))
                st.markdown(f"""
                <div style="background:#1e293b;border:1px solid rgba(20,184,166,0.25);border-left:4px solid {TEAL};
                     border-radius:12px;padding:14px 18px;margin-bottom:9px;
                     box-shadow:0 4px 16px rgba(0,0,0,0.3)">
                    <div style="display:flex;align-items:center;justify-content:space-between">
                        <div style="display:flex;align-items:center;gap:12px;flex:1">
                            <div style="background:rgba(20,184,166,0.1);width:40px;height:40px;border-radius:10px;
                                 display:flex;align-items:center;justify-content:center;font-size:20px;
                                 border:1px solid rgba(20,184,166,0.25)">{icon}</div>
                            <div style="flex:1">
                                <div style="font-size:13px;font-weight:700;color:#f1f5f9">{row["Doctor"]}</div>
                                <div style="font-size:11px;color:#475569;margin-top:2px;font-weight:500">
                                    {row["Department"]} · {row["Seniority"]} · {row["Appointments"]} appts
                                </div>
                                <div style="background:#334155;border-radius:4px;height:4px;margin-top:8px">
                                    <div style="width:{pct}%;height:100%;background:{TEAL};border-radius:4px"></div>
                                </div>
                            </div>
                        </div>
                        <div style="text-align:right;margin-left:16px">
                            <div style="font-size:24px;font-weight:800;color:{TEAL};letter-spacing:-0.5px">{row["No-Show %"]}%</div>
                            <div style="background:rgba(20,184,166,0.12);color:{TEAL};border-radius:6px;padding:2px 8px;
                                 font-size:10px;font-weight:800;display:inline-block;margin-top:4px;
                                 border:1px solid rgba(20,184,166,0.3)">Reliable ✓</div>
                        </div>
                    </div>
                </div>""", unsafe_allow_html=True)

        ch1, ch2 = st.columns(2)
        with ch1:
            st.markdown(sec("📊 No-Show Rate by Doctor"), unsafe_allow_html=True)
            bc2 = [RED if v>30 else ORG if v>26 else BLUE if v>20 else TEAL for v in fdf["No-Show %"]]
            fig = go.Figure(go.Bar(
                x=fdf["Doctor"].str.split("Dr.").str[-1].str.strip(),
                y=fdf["No-Show %"],
                marker=dict(color=bc2, line=dict(width=0), cornerradius=5),
                text=[f"{v}%" for v in fdf["No-Show %"]],
                textposition="outside", textfont=dict(size=11)
            ))
            fig.update_layout(bargap=0.3, xaxis_tickangle=-30)
            st.plotly_chart(sfig(fig, h=300), use_container_width=True)

        with ch2:
            st.markdown(sec("🔵 Appointments vs No-Show","Bubble = Revenue"), unsafe_allow_html=True)
            fig2 = px.scatter(
                fdf, x="Appointments", y="No-Show %",
                size="Revenue", color="Department",
                hover_name="Doctor", text="Doctor",
                color_discrete_map=DEPT_HEX, size_max=48
            )
            fig2.update_traces(textposition="top center", textfont=dict(size=9, color="#94a3b8"))
            st.plotly_chart(sfig(fig2, h=300, legend=True), use_container_width=True)

        # Full table
        st.markdown(sec("📋 Doctor Performance Table"), unsafe_allow_html=True)
        TH = "padding:11px 14px;text-align:left;font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:#475569;font-weight:800;border-bottom:1px solid #334155;background:#243044"

        tbl = f"""<div style="background:#1e293b;border:1px solid #334155;border-radius:12px;overflow:hidden;
             box-shadow:0 4px 16px rgba(0,0,0,0.3)">
        <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead><tr>
            <th style="{TH}">#</th>
            <th style="{TH}">Doctor</th>
            <th style="{TH}">Service Line</th>
            <th style="{TH}">Level</th>
            <th style="{TH};text-align:right">Appts</th>
            <th style="{TH};text-align:right">Revenue</th>
            <th style="{TH};text-align:right">No-Show %</th>
            <th style="{TH};text-align:center">Risk</th>
        </tr></thead><tbody>"""

        for i, (_, row) in enumerate(fdf.iterrows()):
            rc  = RED if i==0 else ORG if i==1 else "#475569"
            c   = ns_color(row["No-Show %"])
            dc  = DEPT_HEX.get(row["Department"], "#64748b")
            di  = DEPT_ICN.get(row["Department"], "🏥")
            bw  = int(min(row["No-Show %"] / 40, 1.0) * 64)
            bg  = "#1a2639" if i % 2 == 0 else "#1e293b"
            tbl += f"""<tr style="background:{bg};border-bottom:1px solid #1e3a5f">
                <td style="padding:11px 14px;color:{rc};font-weight:800">#{i+1}</td>
                <td style="padding:11px 14px;font-weight:700;color:#f1f5f9">{row["Doctor"]}</td>
                <td style="padding:11px 14px">
                    <span style="background:{dc}20;color:{dc};border-radius:5px;padding:2px 8px;
                         font-size:10px;font-weight:800;border:1px solid {dc}40">
                        {di} {row["Department"]}
                    </span>
                </td>
                <td style="padding:11px 14px;color:#64748b;font-weight:500">{row["Seniority"]}</td>
                <td style="padding:11px 14px;text-align:right;font-family:monospace;color:#e2e8f0;font-weight:600">{row["Appointments"]}</td>
                <td style="padding:11px 14px;text-align:right;font-family:monospace;color:{TEAL};font-weight:600">₨{row["Revenue"]}M</td>
                <td style="padding:11px 14px;text-align:right;white-space:nowrap">
                    <span style="font-weight:800;font-size:14px;color:{c}">{row["No-Show %"]}%</span>
                    <div style="background:#334155;border-radius:3px;height:4px;width:64px;
                         margin-top:4px;display:inline-block;vertical-align:middle;margin-left:8px">
                        <div style="width:{bw}px;height:100%;background:{c};border-radius:3px"></div>
                    </div>
                </td>
                <td style="padding:11px 14px;text-align:center">{risk_tag(row["No-Show %"])}</td>
            </tr>"""

        tbl += "</tbody></table></div>"
        st.markdown(tbl, unsafe_allow_html=True)


# ══════════════════════════════════════════════
# TAB 4 — NO-SHOW PREDICTOR
# ══════════════════════════════════════════════
with tab4:

    BASE  = {"General":17.2,"Cardiology":22.0,"Orthopedics":17.0,"Dermatology":23.2,"Pediatrics":17.4}
    C_MOD = {"Karachi":1.05,"Lahore":0.95,"Islamabad":1.02,"Peshawar":1.08,"Multan":0.98}
    D_MOD = {"Mon":1.05,"Tue":1.0,"Wed":1.02,"Thu":0.98,"Fri":1.10,"Sat":0.90,"Sun":1.30}
    P_MOD = {"New Patient":1.20,"Returning":0.85}
    V_MOD = {"First Visit":1.25,"Follow-up":0.90,"Referral":1.10}

    st.markdown(f"""
    <div style="background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.25);
         border-left:4px solid #6366f1;border-radius:12px;padding:13px 20px;margin-bottom:22px;
         display:flex;align-items:center;gap:12px">
        <span style="font-size:18px">🎯</span>
        <span style="font-size:13px;color:#a5b4fc;font-weight:600">
            <b>No-Show Predictor</b> — Configure appointment parameters to get an instant probability
            estimate with actionable recommendations. All controls update in real time.
        </span>
    </div>
    """, unsafe_allow_html=True)

    left, right = st.columns([1, 1], gap="large")

    with left:
        st.markdown("""
        <div style="background:#1e293b;border:1px solid #334155;border-radius:16px;
             border-top:3px solid #6366f1;padding:22px 22px 6px;
             box-shadow:0 4px 20px rgba(0,0,0,0.4)">
            <div style="font-size:14px;font-weight:800;color:#f1f5f9;margin-bottom:3px">
                🗂️ Appointment Parameters
            </div>
            <div style="font-size:11px;color:#475569;margin-bottom:18px;font-weight:500">
                All fields update prediction live
            </div>
        </div>
        """, unsafe_allow_html=True)

        p_dept  = st.selectbox("🏥 Service Line", DEPTS, key="p_dept")
        p_city  = st.selectbox("🌆 City", CITIES, key="p_city")
        p_day   = st.selectbox("📅 Day of Week", ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"], key="p_day")
        p_pt    = st.radio("👤 Patient Type", ["New Patient","Returning"], horizontal=True, key="p_pt")
        p_visit = st.radio("🏷️ Visit Type", ["First Visit","Follow-up","Referral"], horizontal=True, key="p_visit")
        p_adj   = st.slider("⚙️ Manual Adjustment (%)", -10, 10, 0, key="p_adj")

        # Reference tiles
        dept_base = BASE[p_dept]
        city_rate = round(city_df[city_df["city"]==p_city]["noshow"].values[0], 1)
        d_icon    = DEPT_ICN[p_dept]

        st.markdown("<div style='height:10px'></div>", unsafe_allow_html=True)
        bt1, bt2, bt3 = st.columns(3)
        for c_col, label, val, color, bg in [
            (bt1, f"{d_icon} {p_dept}", f"{dept_base}%", BLUE,  "rgba(59,130,246,0.1)"),
            (bt2, f"🌆 {p_city}",       f"{city_rate}%", TEAL,  "rgba(20,184,166,0.1)"),
            (bt3, f"📅 {p_day}",         f"×{D_MOD[p_day]}", VIO, "rgba(139,92,246,0.1)"),
        ]:
            c_col.markdown(f"""
            <div style="background:{bg};border:1px solid {color}30;border-radius:10px;
                 padding:12px 8px;text-align:center">
                <div style="font-size:9px;color:{color};font-weight:800;text-transform:uppercase;
                     letter-spacing:0.8px;margin-bottom:4px">{label}</div>
                <div style="font-size:22px;font-weight:800;color:{color};letter-spacing:-0.5px">{val}</div>
            </div>""", unsafe_allow_html=True)

    with right:
        prob = BASE[p_dept] * C_MOD[p_city] * D_MOD[p_day] * P_MOD[p_pt] * V_MOD[p_visit]
        prob = max(min(round(prob + p_adj, 1), 99.0), 1.0)

        if prob < 20:
            rlbl, rc, rbg, rbdr = "Low Risk",    TEAL, "rgba(20,184,166,0.08)",  "rgba(20,184,166,0.3)"
            recs = ["Send standard SMS reminder","No special action needed","Standard scheduling applies"]
            rec_icon = "✅"
        elif prob < 28:
            rlbl, rc, rbg, rbdr = "Medium Risk", ORG,  "rgba(249,115,22,0.08)",  "rgba(249,115,22,0.3)"
            recs = ["Send WhatsApp reminder 24h before","Avoid overbooking this slot","Follow up if no confirmation received"]
            rec_icon = "⚠️"
        else:
            rlbl, rc, rbg, rbdr = "High Risk",   RED,  "rgba(239,68,68,0.08)",   "rgba(239,68,68,0.3)"
            recs = ["Call patient directly to confirm","Consider double-booking","Alert scheduling coordinator"]
            rec_icon = "🚨"

        # Gauge chart
        gauge_fig = go.Figure(go.Indicator(
            mode="gauge+number",
            value=prob,
            number={"suffix":"%","font":{"size":52,"family":"Inter","color":rc}},
            gauge={
                "axis":{"range":[0,100],"tickwidth":1,"tickcolor":"#475569","tickfont":{"size":10,"color":"#475569"}},
                "bar":{"color":rc,"thickness":0.28},
                "bgcolor":"#243044",
                "borderwidth":0,
                "steps":[
                    {"range":[0,20],  "color":"rgba(20,184,166,0.12)"},
                    {"range":[20,28], "color":"rgba(249,115,22,0.12)"},
                    {"range":[28,100],"color":"rgba(239,68,68,0.12)"},
                ],
                "threshold":{"line":{"color":rc,"width":3},"thickness":0.75,"value":prob}
            }
        ))
        gauge_fig.update_layout(
            paper_bgcolor="#1e293b",
            font=dict(color="#64748b", family="Inter"),
            height=250,
            margin=dict(l=20,r=20,t=20,b=10)
        )

        st.markdown(f"""
        <div style="background:#1e293b;border:2px solid {rbdr};border-radius:16px;
             border-top:3px solid {rc};padding:22px 24px;
             box-shadow:0 8px 32px rgba(0,0,0,0.5)">
            <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;
                 color:#475569;text-align:center;margin-bottom:8px">
                Estimated No-Show Probability
            </div>
        """, unsafe_allow_html=True)

        st.plotly_chart(gauge_fig, use_container_width=True)

        pct_bar = int((prob / 100) * 100)
        st.markdown(f"""
            <div style="display:flex;justify-content:center;margin:-8px 0 16px">
                <div style="background:{rbg};color:{rc};border:2px solid {rbdr};border-radius:9px;
                     padding:7px 24px;font-size:14px;font-weight:800;letter-spacing:0.3px">
                    {rec_icon} {rlbl}
                </div>
            </div>

            <div style="background:#334155;border-radius:8px;height:10px;margin-bottom:6px">
                <div style="width:{pct_bar}%;height:100%;
                     background:linear-gradient(90deg,{rc}80,{rc});border-radius:8px;
                     transition:width 0.6s ease"></div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:9px;
                 color:#334155;font-weight:700;margin-bottom:18px">
                <span>0%</span><span>20% Low</span><span>28% Med</span><span>100%</span>
            </div>

            <div style="background:{rbg};border:1px solid {rbdr};border-radius:11px;padding:14px 16px">
                <div style="font-size:10px;font-weight:800;color:{rc};text-transform:uppercase;
                     letter-spacing:1px;margin-bottom:10px">📋 Recommended Actions</div>
        """, unsafe_allow_html=True)

        for r_item in recs:
            st.markdown(f"""
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                    <div style="width:6px;height:6px;background:{rc};border-radius:50%;flex-shrink:0"></div>
                    <span style="font-size:12px;color:#94a3b8;font-weight:600">{r_item}</span>
                </div>""", unsafe_allow_html=True)

        st.markdown("</div></div>", unsafe_allow_html=True)

        # Factor chips
        st.markdown("<div style='height:14px'></div>", unsafe_allow_html=True)
        st.markdown('<div style="font-size:9px;font-weight:800;color:#334155;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px">Contributing Factors</div>', unsafe_allow_html=True)

        f1, f2, f3, f4, f5 = st.columns(5)
        factors = [
            (d_icon,  "Dept",  p_dept,   f"{dept_base}% base",          BLUE),
            ("🌆",    "City",  p_city,   f"×{C_MOD[p_city]}",           TEAL),
            ("📅",    "Day",   p_day,    f"×{D_MOD[p_day]}",            VIO),
            ("👤",    "Type",  "New" if "New" in p_pt else "Return",
                                          "+20%" if "New" in p_pt else "−15%", ORG),
            ("🏷️",   "Visit", p_visit.split()[0],
                                          f"×{V_MOD[p_visit]}",          PINK),
        ]
        for col, (icon, label, val, eff, color) in zip([f1,f2,f3,f4,f5], factors):
            col.markdown(f"""
            <div style="background:#1e293b;border:1px solid #334155;border-radius:10px;
                 border-top:2px solid {color};padding:10px 6px;text-align:center">
                <div style="font-size:9px;color:{color};text-transform:uppercase;letter-spacing:0.8px;
                     font-weight:800;margin-bottom:4px">{label}</div>
                <div style="font-size:17px">{icon}</div>
                <div style="font-size:11px;font-weight:800;color:#f1f5f9;margin-top:3px">{val}</div>
                <div style="font-size:10px;color:#475569;font-weight:500">{eff}</div>
            </div>""", unsafe_allow_html=True)

# ── FOOTER ──
st.markdown("<div style='height:40px'></div>", unsafe_allow_html=True)
st.markdown("""
<div style="text-align:center;padding:18px;border-top:1px solid #1e3a5f">
    <span style="font-size:10px;color:#1e3a5f;font-weight:700;letter-spacing:1.5px;text-transform:uppercase">
