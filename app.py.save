# TAB 1 — REVENUE & TRENDS
# ══════════════════════════════════════════════
with tab1:

    # Filter bar
    fc1, fc2, fc3 = st.columns([2, 2.5, 1.5])
    with fc1:
        city_t1 = st.multiselect("🏙️ Filter Cities", CITIES, default=CITIES, key="t1_c")
    with fc2:
        dr = st.radio("📅 Period", ["Last 3 Months","Last 6 Months","Full Year 2024"], horizontal=True, key="t1_dr")
    with fc3:
        show_avg = st.checkbox("Show rolling avg", value=True, key="t1_avg")

    n_mo = {"Last 3 Months":3,"Last 6 Months":6,"Full Year 2024":12}[dr]
    mdf  = monthly.tail(n_mo).copy()

    st.markdown("<div style='height:8px'></div>", unsafe_allow_html=True)

    # Row 1
    r1a, r1b = st.columns(2)

    with r1a:
        st.markdown(sec("🏙️ Revenue by City","PKR millions"), unsafe_allow_html=True)
        bar_c = [TEAL if v == max(city_df["revenue"]) else "#1e4d7b" for v in city_df["revenue"]]
        fig = go.Figure(go.Bar(
            x=city_df["city"], y=city_df["revenue"],
            marker=dict(color=bar_c, line=dict(width=0), cornerradius=6),
            text=[f"₨{v}M" for v in city_df["revenue"]],
            textposition="outside",
            textfont=dict(size=11, color="#94a3b8"),
        ))
        fig.update_layout(bargap=0.38)
        st.plotly_chart(sfig(fig), use_container_width=True)

        p_cols = st.columns(5)
        for i, (_, row) in enumerate(city_df.iterrows()):
            c  = TEAL if row["trend"] >= 0 else RED
            bg = "rgba(20,184,166,0.1)" if row["trend"] >= 0 else "rgba(239,68,68,0.1)"
            ar = "↑" if row["trend"] >= 0 else "↓"
            p_cols[i].markdown(f"""
            <div style="background:{bg};color:{c};border-radius:7px;padding:5px 3px;
                 text-align:center;font-size:10px;font-weight:700;margin-top:-6px;
                 border:1px solid {c}33">
                {row['city']}<br><span style="font-size:12px">{ar}{abs(row['trend'])}%</span>
            </div>""", unsafe_allow_html=True)

    with r1b:
        st.markdown(sec("📅 Monthly Appointment Trend",f"Last {n_mo} months"), unsafe_allow_html=True)
        fig2 = go.Figure()
        fig2.add_trace(go.Scatter(
            x=mdf["month"], y=mdf["appts"],
            mode="lines+markers",
            line=dict(color=BLUE, width=2.8, shape="spline"),
            marker=dict(size=8, color=BLUE, line=dict(color="#0f172a", width=2)),
            fill="tozeroy",
            fillcolor="rgba(59,130,246,0.08)",
            name="Appointments"
        ))
        if show_avg:
            fig2.add_trace(go.Scatter(
                x=mdf["month"], y=mdf["appts"].rolling(3, min_periods=1).mean(),
                mode="lines",
                line=dict(color=ORG, width=2, dash="dot"),
                name="Rolling avg"
            ))
        st.plotly_chart(sfig(fig2, legend=True), use_container_width=True)

    # Row 2
    r2a, r2b = st.columns(2)

    with r2a:
        st.markdown(sec("💰 Monthly Revenue","PKR 2024"), unsafe_allow_html=True)
        fig3 = go.Figure(go.Bar(
            x=mdf["month"].dt.strftime("%b"),
            y=mdf["rev"],
            marker=dict(
                color=mdf["rev"],
                colorscale=[[0,"#1e3a5f"],[0.5,TEAL],[1,"#67e8f9"]],
                line=dict(width=0),
                cornerradius=5
            ),
            text=[f"₨{v/1e6:.2f}M" for v in mdf["rev"]],
            textposition="outside",
            textfont=dict(size=10, color="#64748b")
        ))
        fig3.update_layout(bargap=0.28)
        st.plotly_chart(sfig(fig3), use_container_width=True)

    with r2b:
        st.markdown(sec("📆 Volume by Day of Week","With no-show overlay"), unsafe_allow_html=True)
        fig4 = make_subplots(specs=[[{"secondary_y": True}]])
        day_c = [RED if d=="Sun" else BLUE if d in ["Mon","Thu"] else "#1e4d7b" for d in days_df["day"]]
        fig4.add_trace(go.Bar(
            x=days_df["day"], y=days_df["count"],
            marker=dict(color=day_c, line=dict(width=0), cornerradius=4),
            name="Appointments",
            text=days_df["count"].apply(lambda v: f"{v:,}"),
            textposition="outside",
            textfont=dict(size=10, color="#64748b")
        ), secondary_y=False)
        fig4.add_trace(go.Scatter(
            x=days_df["day"], y=days_df["noshow_rate"],
            mode="lines+markers",
            name="No-Show %",
            line=dict(color=ORG, width=2.5, dash="dot"),
            marker=dict(size=7, color=ORG, line=dict(color="#0f172a", width=1.5))
        ), secondary_y=True)
        fig4.update_layout(
            paper_bgcolor=PBG, plot_bgcolor=PBG,
            height=320, margin=dict(l=8,r=8,t=30,b=8),
            bargap=0.3, showlegend=True,
            legend=dict(bgcolor="rgba(0,0,0,0)", borderwidth=0, font=dict(size=11, color="#64748b")),
            font=dict(family="Inter", color="#64748b", size=11),
            xaxis=dict(gridcolor=PGRD, linecolor="#334155", tickfont=dict(size=11,color="#64748b")),
            yaxis=dict(gridcolor=PGRD, linecolor="rgba(0,0,0,0)", tickfont=dict(size=11,color="#64748b")),
            yaxis2=dict(tickfont=dict(size=11, color=ORG), showgrid=False)
        )
        st.plotly_chart(fig4, use_container_width=True)

    # Row 3 — stacked outcome
    st.markdown(sec("📉 Monthly Outcome Breakdown","Completion vs No-Show vs Cancelled (%)"), unsafe_allow_html=True)
    fig5 = go.Figure()
    fig5.add_trace(go.Scatter(
        x=mdf["month"], y=mdf["completed"],
        mode="lines", line=dict(color=TEAL, width=0),
        fill="tozeroy", fillcolor="rgba(20,184,166,0.18)",
        name="Completed %", stackgroup="one"
    ))
    fig5.add_trace(go.Scatter(
        x=mdf["month"], y=mdf["noshow"],
        mode="lines", line=dict(color=ORG, width=0),
        fill="tonexty", fillcolor="rgba(249,115,22,0.22)",
        name="No-Show %", stackgroup="one"
    ))
    fig5.add_trace(go.Scatter(
        x=mdf["month"], y=mdf["cancelled"],
        mode="lines", line=dict(color=RED, width=0),
        fill="tonexty", fillcolor="rgba(239,68,68,0.18)",
        name="Cancelled %", stackgroup="one"
    ))
    fig5.add_hline(y=18.8, line_dash="dot", line_color=ORG,
                   annotation_text="Avg No-Show 18.8%",
                   annotation_font=dict(color=ORG, size=11),
                   annotation_bgcolor="rgba(0,0,0,0)")
    st.plotly_chart(sfig(fig5, h=260, legend=True), use_container_width=True)

    # Row 4 — satisfaction + city noshow
    r4a, r4b = st.columns(2)
    with r4a:
        st.markdown(sec("⭐ Patient Satisfaction by City","Rating out of 5.0"), unsafe_allow_html=True)
        fig_s = go.Figure(go.Bar(
            x=city_df["city"], y=city_df["satisfaction"],
            marker=dict(
                color=city_df["satisfaction"],
                colorscale=[[0,"#1e4d7b"],[0.5,BLUE],[1,TEAL]],
                line=dict(width=0), cornerradius=6
            ),
            text=[f"⭐ {v}" for v in city_df["satisfaction"]],
            textposition="outside", textfont=dict(size=12)
        ))
        fig_s.update_layout(yaxis_range=[3.5,5])
        st.plotly_chart(sfig(fig_s, h=260), use_container_width=True)

    with r4b:
        st.markdown(sec("🗺️ No-Show Rate by City","vs network avg 18.8%"), unsafe_allow_html=True)
        clr_ns = [RED if v>19.5 else ORG if v>18.5 else TEAL for v in city_df["noshow"]]
        fig_n = go.Figure(go.Bar(
            x=city_df["noshow"],
            y=city_df["city"],
            orientation="h",
            marker=dict(color=clr_ns, line=dict(width=0), cornerradius=5),
            text=[f"{v}%" for v in city_df["noshow"]],
            textposition="outside", textfont=dict(size=12)
        ))
        fig_n.add_vline(x=18.8, line_dash="dot", line_color="#475569",
                        annotation_text="Avg 18.8%",
                        annotation_font=dict(color="#64748b", size=11))
        st.plotly_chart(sfig(fig_n, h=260), use_container_width=True)


